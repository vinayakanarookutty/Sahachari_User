{
  "expo": {
    "name": "Sahachari",
    "slug": "customers",
    "version": "1.0.29",
    "orientation": "portrait",
    "icon": "./assets/sahachari.jpeg",
    "scheme": "customers",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.corestoneinnovation.sahachariuser",
      "buildNumber": "29"
    },
    "android": {
      "package": "com.corestoneinnovation.sahachariuser",
      "versionCode": 29,
      "adaptiveIcon": {
        "foregroundImage": "./assets/sahachari.jpeg",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true
    },
    "splash": {
      "image": "./assets/sahachari.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/sahachari.jpeg"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/sahachari.jpeg",
          "color": "#2563EB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77756b3c-c127-412b-a5aa-03472f872186"
      }
    }
  }
}
